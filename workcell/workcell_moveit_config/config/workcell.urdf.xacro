<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="workcell">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import workcell urdf file -->
    <xacro:include filename="$(find workcell_description)/urdf/workcell.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="workcell.ros2_control.xacro" />


    <xacro:workcell_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
