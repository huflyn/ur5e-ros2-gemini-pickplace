<?xml version="1.0"?>
<robot name="workcell" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="$(find workcell_description)/urdf/workcell_macro.xacro"/>

  <xacro:arg name="ur_type" default="ur5e"/>
  <xacro:arg name="joint_limits_parameters_file" default="$(find ur_description)/config/$(arg ur_type)/joint_limits.yaml"/>
  <xacro:arg name="kinematics_parameters_file" default="$(find workcell_description)/config/my_robot_calibration.yaml"/>
  <xacro:arg name="physical_parameters_file" default="$(find ur_description)/config/$(arg ur_type)/physical_parameters.yaml"/>
  <xacro:arg name="visual_parameters_file" default="$(find ur_description)/config/$(arg ur_type)/visual_parameters.yaml"/>
  <!-- Arguments for the Realsense D415 -->
  <xacro:arg name="use_nominal_extrinsics" default="false" />
  <xacro:arg name="add_plug" default="true" />
  <xacro:arg name="use_mesh" default="false" />

  <!-- World Link (represents the origin of the world coordinate frame) -->
  <link name="world"/>

  <!-- This will create the scene where the robot is located in -->
  <xacro:workcell
    parent="world"
    ur_type="$(arg ur_type)"
    joint_limits_parameters_file="$(arg joint_limits_parameters_file)"
    kinematics_parameters_file="$(arg kinematics_parameters_file)"
    physical_parameters_file="$(arg physical_parameters_file)"
    visual_parameters_file="$(arg visual_parameters_file)"
    use_nominal_extrinsics="$(arg use_nominal_extrinsics)"
    add_plug="$(arg add_plug)"
    use_mesh="$(arg use_mesh)"
    >
    <origin xyz="0 0 0" rpy="0 0 0" />
  </xacro:workcell>

</robot>